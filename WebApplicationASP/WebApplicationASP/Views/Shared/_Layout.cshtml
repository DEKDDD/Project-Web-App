<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/css/style.css" />
</head>

<body>

<nav class="navbar">

    <a asp-controller="Home" asp-action="Index" class="index-link">
        <div class="logo">CE Web</div>
    </a>

    <div class="nav_auth">
    @if (User.Identity.IsAuthenticated)
    {
        @* ดึง URL รูปจาก Claim *@
        var profilePic = User.FindFirst("ProfileImage")?.Value ?? "/images/default.jpg";

        <div class="profile-dropdown" style="position: relative; display: inline-block;">

            @* เปลี่ยนจากชื่อ เป็นรูปภาพ *@
            <button class="button_auth" onclick="toggleProfileMenu(event)" 
                    style="display: flex; align-items: center; padding: 0; border-radius: 50%; width: 50px; height: 50px; overflow: hidden; border: 2px solid white; background: none;">
                <img src="@profilePic" 
                    class="nav-profile-img"
                    alt="Profile" 
                    style="width: 100%; height: 100%; object-fit: cover;" />
            </button>

            <div id="profileMenu" class="profile-menu">
                @* แสดงชื่อข้างในเมนูแทน (ถ้ายังอยากให้เห็นชื่อ) *@
                <div style="padding: 10px; border-bottom: 1px solid #eee; font-weight: bold; color: #333;">
                    @User.Identity.Name
                </div>

                <a asp-controller="User" asp-action="Profile">
                    My Profile
                </a>

                <form method="post" asp-controller="Auth" asp-action="Logout">
                    <button type="submit" style="width: 100%; text-align: left; background: none; border: none; padding: 10px 20px; cursor: pointer; color: red;">
                        Logout
                    </button>
                </form>
            </div>
        </div>
    }
    else
    {
        <a asp-controller="Auth" asp-action="Login">
            <button class="button_auth">Log in</button>
        </a>

        <a asp-controller="Auth" asp-action="Signup">
            <button class="button_auth">Sign Up</button>
        </a>
    }
    
    </div>
</nav>

<!-- เนื้อหาของแต่ละหน้า -->
@RenderBody()


<script src="~/js/index.js"></script>

</body>
</html>