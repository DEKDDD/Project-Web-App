@{
  ViewData["Title"] = "Home Page";

  string GetCategoryWithEmoji(string category)
  {
    var c = category.Trim().ToLower();
    if (c == "sport") return "กีฬา ⚽";
    if (c == "music") return "ดนตรี 🎵 ";
    if (c == "food") return "อาหาร 🍔";
    return "ทั่วไป 💬";
  }
}
@model List<Activity>
<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"]</title>
  <link rel="stylesheet" href="~/css/style.css" />
</head>

<body>
  <main class="container">
    <section class="search_section">
      <a asp-controller="Activity" asp-action="AddActivity">
        <button class="button_new">New</button>
      </a>
      <input type="text" placeholder="Search by keywords..." class="search_input" id="search-input" />
      <button id="openFilter" class="button_filter" onclick="toggleFilterMenu(event)">Filter</button>
      <div id="filterMenu" class="side-menu">
        <div class="menu-content">
          <span class="close-btn" onclick="toggleFilterMenu(event)">&times;</span>
          <h3>ตัวเลือกการกรอง</h3>
          <hr>
          <h4>สถานะกิจกรรม</h4>
          <label><input type="checkbox" class="status-checkbox" value="open"> กิจกรรมที่เปิดรับอยู่</label><br>
          <label><input type="checkbox" class="status-checkbox" value="close"> กิจกรรมที่ปิดรับแล้ว</label><br>
          <hr>
          <h4>ประเภทของกิจกรรม</h4>
          <label><input type="checkbox" class="category-checkbox" value="sport"> กีฬา</label><br>
          <label><input type="checkbox" class="category-checkbox" value="music"> ดนตรี</label><br>
          <label><input type="checkbox" class="category-checkbox" value="food"> อาหาร</label><br>
          <h4>ลักษณะการกรอง</h4>
          <label class="switch">
            <input type="checkbox" id="logic-switch">
            <span class="slider"></span>
          </label>
        </div>
      </div>
    </section>

    <h2>Activity List</h2>
    <div id="event-list" class="activity_grid">
      @foreach (var activity in Model)
      {
        <div class="activity_card_container" data-status="@activity.Status" data-category="@string.Join(",", activity.Category)">

          <div class="activity_card" data-id="@activity.Id" onclick="openModal(this)" >
            <img src="@activity.ImageUrl" class="activity_img" onerror="this.src='/images/No Image.png';" />
            <div class="activity_info">
              <h3 class="card-title">@activity.Title</h3>
              <p class="card-description">@activity.Description</p>
              <p>เหลือที่ว่าง <span class="available-seat">@(activity.Number - activity.Member.Count)</span> คน</p>
              <div class="card-tags">
                <span class="category">ประเภท: @string.Join(", ", activity.Category.Select(c =>
                                                                                                    GetCategoryWithEmoji(c)))</span>
                  <span class="status activity-status @(activity.Status == "open" ? "status_open" : "status_close")"
                        data-status="@activity.Status" data-expire="@activity.ExpireDate.ToString("yyyy-MM-ddTHH:mm:ss")">
                    Status: @activity.Status
                  </span>
                </div>
              </div>
            </div>
          </div>
        }
      </div>
    </main>

    <div class="activity-container">
      @foreach (var item in Model)
      {
        <div class="card" data-id="@item.Id" onclick="openModal(this)">
        </div>
      }
    </div>

    <div id="customModal" class="custom-modal">
      <div class="custom-modal-content">
        <span class="custom-close-btn" onclick="closeModal()">&times;</span>

        <img id="modalImage" class="modal-banner" src="" onerror="this.src='/images/No Image.png';" />

        <h3 id="modalTitle" class="modal-title">ชื่อกิจกรรม</h3>
        <p class="modal-host"><strong>Host:</strong> <span id="modalHost"></span></p>
        <hr>

        <p><strong>รายละเอียด:</strong> <span id="modalDescription"></span></p>
        <p><strong>วันที่ปิดรับสมัคร:</strong> <span id="modalExpireDate"></span></p>
        <p><strong>ประเภท:</strong> <span id="modalCategory"></span></p>

        <p>
          <strong>สมัครแล้ว:</strong> <span id="modalMemberCount"></span>/<span id="modalmaxParticipants"></span> คน
          <button id="toggleMembersBtn" class="btn-toggle-members" onclick="toggleMembers()">ดูรายชื่อ</button>
        </p>

        <div id="membersListContainer" class="members-container">
          <ul id="modalMembersList" class="members-list"></ul>
        </div>

        <p><strong>คงเหลือ:</strong> <span id="modalEmptySeats" class="text-blue"></span> ที่</p>
        <p><strong>สถานะ:</strong> <span id="modalStatus" class="text-status"></span></p>

        <div class="modal-footer">
          <button id="joinActivityBtn" class="btn-primary-join" onclick="joinActivity()">Join</button>
          <a id="editActivityBtn" class="btn-warning-edit" href="#">✏️ แก้ไขกิจกรรม</a>
        </div>
      </div>
    </div>

    <script src="~/js/index.js"></script>
    <script>
      setInterval(function () {
      var now = new Date();
      var statusElements = document.querySelectorAll('.activity-status');

      statusElements.forEach(function (el) {
      var status = el.getAttribute('data-status');
      var expireStr = el.getAttribute('data-expire');

      if (status === 'open' && expireStr) {
      var expireDate = new Date(expireStr);

      if (now >= expireDate) {
      el.innerText = 'Status: close';
      el.className = 'status activity-status status_close';
      el.setAttribute('data-status', 'close');
      }
      }
      });
      }, 1000);
    </script>
  </body>

</html>