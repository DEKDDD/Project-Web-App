@{
    ViewData["Title"] = "Home Page";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/style.css" />
</head>

<body>
    <main class="container">
      <section class="search_section">
        <a href="create_act.html">
        <button class="button_new">New</button>
        </a>
        <input
          type="text"
          placeholder="Search by keywords..."
          class="search_input"
        />
        <button id="openFilter" class="button_filter" onclick="toggleFilterMenu(event)">Filter</button>
          <div id="filterMenu" class="side-menu">
            <div class="menu-content">
              <span class="close-btn" onclick="toggleFilterMenu(event)">&times;</span>
              <h3>ตัวเลือกการกรอง</h3>
              <hr>
              <h4>สถานะกิจกรรม</h4>
              <label><input type="checkbox" class="status-checkbox" value="open"> กิจกรรมที่เปิดรับอยู่</label><br>
              <label><input type="checkbox" class="status-checkbox" value="close"> กิจกรรมที่ปิดรับแล้ว</label><br>
              <hr>
              <h4>ประเภทของกิจกรรม</h4>
              <label><input type="checkbox" class="category-checkbox" value="กีฬา"> กีฬา</label><br>
              <label><input type="checkbox" class="category-checkbox" value="ดนตรี"> ดนตรี</label><br>
              <label><input type="checkbox" class="category-checkbox" value="อาหาร"> อาหาร</label><br>
              <br>
              <button class="apply-btn">ตกลง</button>
            </div>
          </div>
      </section>

      <h2>Available Activity</h2>
      <div id="event-list" class="activity_grid">
        <a href="detail.html" class="activity_card_link" data-category="กีฬา" data-status="open">
          <div class="activity_card">
            <img src="cat.jpg" alt="cat" class="activity_img" />
            <div class="activity_info">
              <h3>Activity Name</h3>
              <p>Description Activity Card...</p>
              <span class="status status_open">Status: Open</span>
            </div>
          </div>
        </a>
        <a href="detail.html" class="activity_card_link" data-category="ดนตรี" data-status="open">
          <div class="activity_card">
            <img src="cat.jpg" alt="cat" class="activity_img" />
            <div class="activity_info">
              <h3>Activity Name</h3>
              <p>Description Activity Card...</p>
              <span class="status status_open">Status: Open</span>
            </div>
          </div>
        </a>
        <a href="detail.html" class="activity_card_link" data-category="อาหาร" data-status="open">
          <div class="activity_card">
            <img src="cat.jpg" alt="cat" class="activity_img" />
            <div class="activity_info">
              <h3>Activity Name</h3>
              <p>Description Activity Card...</p>
              <span class="status status_open">Status: Open</span>
            </div>
          </div>
        </a>
        <a href="detail.html" class="activity_card_link" data-category="กีฬา" data-status="close">
        <div class="activity_card">
          <img src="cat.jpg" alt="cat" class="activity_img" />
          <div class="activity_info">
            <h3>Activity Name</h3>
            <p>Description Activity Card...</p>
            <span class="status status_close">Status: Close</span>
          </div>
        </div>
        </a>
        <a href="detail.html" class="activity_card_link" data-category="ดนตรี" data-status="close">
        <div class="activity_card">
          <img src="cat.jpg" alt="cat" class="activity_img" />
          <div class="activity_info">
            <h3>Activity Name</h3>
            <p>Description Activity Card...</p>
            <span class="status status_close">Status: Close</span>
          </div>
        </div>
        </a>
        <a href="detail.html" class="activity_card_link" data-category="อาหาร" data-status="close">
        <div class="activity_card">
          <img src="cat.jpg" alt="cat" class="activity_img" />
          <div class="activity_info">
            <h3>Activity Name</h3>
            <p>Description Activity Card...</p>
            <span class="status status_close">Status: Close</span>
          </div>
        </div>
        </a>
      </div>
    </main>

    <script src="~/js/index.js"></script>
</body>
</html>
