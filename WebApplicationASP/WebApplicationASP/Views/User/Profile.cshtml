@using WebApplicationASP.Models
@model User
@{
    ViewData["Title"] = "Profile";

    string GetCategoryWithEmoji(string category)
    {
        var c = category.Trim().ToLower();
        if (c == "sport") return "กีฬา ⚽";
        if (c == "music") return "ดนตรี 🎵 ";
        if (c == "food") return "อาหาร 🍔";
        return "ทั่วไป 💬";
    }
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/style.css" />
</head>

<body>
    <div class="profile-page-wrapper">
        <div class="profile-section">
            <img src="@(string.IsNullOrEmpty(Model.ProfileImage) ? "/images/default.jpg" : Model.ProfileImage)" alt="profile" class="profile_img" />
            <h1 class="username">@Model.Username</h1>
            <div class="upload-section" >
                <button type="button" class="button_edit" onclick="document.getElementById('fileInput').click()" >
                    📷 เปลี่ยนรูปโปรไฟล์
                </button>
    
                <input type="file" class="file_input" id="fileInput" accept="image/*" onchange="uploadProfileImage(this)" />
    
                <span id="uploadStatus" class="upload_status"></span>
            </div>
        </div>

        <h2 class="section-title">กิจกรรมที่ลง</h2>
        <div class="activity_grid">
            @if (ViewBag.JoinedActivities != null && ((List<Activity>)ViewBag.JoinedActivities).Any())
            {
                @foreach (var activity in (List<Activity>)ViewBag.JoinedActivities)
                {
                    <div class="activity_card_container" data-id="@activity.Id" onclick="openModal(this)">
                        <div class="activity_card">
                            <img src="@activity.ImageUrl" class="activity_img" onerror="this.src='/images/No Image.png';" />
                            <div class="activity_info">
                                <h3 class="card-title">@activity.Title</h3>
                                <p class="card-description">@activity.Description</p>
                                <div class="card-tags">
                                    <span class="category">ประเภท: @string.Join(", ", activity.Category.Select(c => GetCategoryWithEmoji(c)))</span>
                                    <span class="status @(activity.Status == "open" ? "status_open" : "status_close")">Status: @activity.Status</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="blank_grid">ยังไม่มีกิจกรรมที่เข้าร่วม</p>
            }
        </div>

        <h2 class="section-title">กิจกรรมที่สร้าง</h2>
        <div class="activity_grid">
            @if (ViewBag.CreatedActivities != null && ((List<Activity>)ViewBag.CreatedActivities).Any())
            {
                @foreach (var activity in (List<Activity>)ViewBag.CreatedActivities)
                {
                    <div class="activity_card_container" data-id="@activity.Id" onclick="openModal(this)">
                        <div class="activity_card">
                            <img src="@activity.ImageUrl" class="activity_img" onerror="this.src='/images/No Image.png';" />
                            <div class="activity_info">
                                <h3 class="card-title">@activity.Title</h3>
                                <p class="card-description">@activity.Description</p>
                                <div class="card-tags">
                                    <span class="category">ประเภท: @string.Join(", ", activity.Category.Select(c => GetCategoryWithEmoji(c)))</span>
                                    <span class="status @(activity.Status == "open" ? "status_open" : "status_close")">Status: @activity.Status</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="blank_grid">ยังไม่ได้สร้างกิจกรรม</p>
            }
        </div>
    </div>

    <div id="customModal" class="custom-modal">
    <div class="custom-modal-content">
        <span class="custom-close-btn" onclick="closeModal()">&times;</span>
        
        <img id="modalImage" class="modal-image" src="" onerror="this.src='/images/No Image.png';" />
        
        <h3 id="modalTitle" class="modal-title"></h3>
        <p class="modal-host-text"><strong>Host:</strong> <span id="modalHost"></span></p>
        <hr>
        
        <p><strong>รายละเอียด:</strong> <span id="modalDescription"></span></p>
        <p><strong>วันที่ปิดรับสมัคร:</strong> <span id="modalExpireDate"></span></p>
        <p><strong>ประเภท:</strong> <span id="modalCategory"></span></p>
        
        <p>
            <strong>สมัครแล้ว:</strong> 
            <span id="modalMemberCount"></span> / <span id="modalmaxParticipants"></span> คน
            <button id="toggleMembersBtn" class="btn-toggle-list" onclick="toggleMembers()">ดูรายชื่อ</button>
        </p>

        <div id="membersListContainer" class="members-list-container">
            <ul id="modalMembersList" class="modal-members-list"></ul>
        </div>

        <p><strong>คงเหลือ:</strong> <span id="modalEmptySeats" class="text-remaining"></span> ที่</p>
        <p><strong>สถานะ:</strong> <span id="modalStatus" class="text-status"></span></p>

        <div class="modal-actions">
            <button id="joinActivityBtn" class="btn-join" onclick="joinActivity()">Join</button>
            <a id="editActivityBtn" class="btn-edit" href="#">✏️ แก้ไขกิจกรรม</a>
        </div>
    </div>
</div>

    <a asp-controller="Home" asp-action="Index" class="close-button">X</a>

    <script src="~/js/index.js"></script>

    <script>
        window.addEventListener('click', function(event) {
            var modal = document.getElementById('customModal');
            if (event.target == modal) { 
                if(typeof closeModal === "function") {
                    closeModal();
                } else {
                    modal.style.display = "none";
                }
            }
        });
    </script>
</body>
</html>